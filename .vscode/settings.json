{
  // Use nightly rustfmt (rustfmt.toml relies on unstable features)
  "rust-analyzer.rustfmt.extraArgs": ["+nightly", "--unstable-features"],

  // Match rustfmt.toml import settings
  "rust-analyzer.imports.granularity.group": "crate",
  "rust-analyzer.imports.granularity.enforce": true,
  "rust-analyzer.imports.prefix": "crate"
}
